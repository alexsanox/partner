{
  "name": "partner-hosting",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run --filter './apps/web' dev",
    "build": "bun run --filter './apps/web' build",
    "lint": "bun run --filter '*' lint",
    "worker": "bun run --filter './apps/worker' start",
    "worker:dev": "bun run --filter './apps/worker' dev",
    "db:generate": "bun run --filter './packages/db' generate",
    "db:push": "bun run --filter './packages/db' push",
    "db:migrate": "bun run --filter './packages/db' migrate",
    "db:studio": "bun run --filter './packages/db' studio",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.4.0",
    "canvas-confetti": "^1.9.4",
    "stripe": "^22.1.1"
  }
}
